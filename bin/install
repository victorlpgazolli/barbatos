#!/usr/bin/env bash
set -e

ASDF_INSTALL_TYPE=$1
ASDF_INSTALL_VERSION=$2
ASDF_INSTALL_PATH=$3
ASDF_DOWNLOAD_PATH=$4

mkdir -p "$ASDF_INSTALL_PATH/bin"
cp "$ASDF_DOWNLOAD_PATH/dist/barbatos" "$ASDF_INSTALL_PATH/bin/barbatos"
cp "$ASDF_DOWNLOAD_PATH/dist/barbatos-bridge" "$ASDF_INSTALL_PATH/bin/barbatos-bridge"
cp "$ASDF_DOWNLOAD_PATH/dist/barbatos-mcp" "$ASDF_INSTALL_PATH/bin/barbatos-mcp"
chmod +x "$ASDF_INSTALL_PATH/bin/"*

echo "barbatos ${ASDF_INSTALL_VERSION} installation successful!"
