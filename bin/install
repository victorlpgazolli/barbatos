#!/usr/bin/env bash
set -euo pipefail

install_path="$ASDF_INSTALL_PATH"
download_path="$ASDF_DOWNLOAD_PATH"

mkdir -p "$install_path/bin"
cp "$download_path/dist/barbatos" "$install_path/bin/barbatos"
cp "$download_path/dist/barbatos-bridge" "$install_path/bin/barbatos-bridge"
cp "$download_path/dist/barbatos-mcp" "$install_path/bin/barbatos-mcp"
chmod +x "$install_path/bin/"*

echo "barbatos ${ASDF_INSTALL_VERSION} installation successful!"
