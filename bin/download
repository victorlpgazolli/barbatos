#!/usr/bin/env bash
set -euo pipefail

version="$ASDF_INSTALL_VERSION"
download_path="$ASDF_DOWNLOAD_PATH"

OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

if [ "$OS" = "darwin" ]; then
    OS="macos"
fi

if [ "$ARCH" = "x86_64" ]; then
    ARCH="x64"
elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
    ARCH="arm64"
fi

# ASSETS in GitHub are named: barbatos-macos-arm64.zip or barbatos-linux-x64.zip
url="https://github.com/victorlpgazolli/barbatos/releases/download/v${version}/barbatos-${OS}-${ARCH}.zip"

echo "Downloading barbatos v${version} for ${OS}-${ARCH}..."
curl -fLo "${download_path}/barbatos.zip" "$url"
cd "${download_path}"
unzip barbatos.zip
rm barbatos.zip
